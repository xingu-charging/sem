{
  "name": "@xingu-charging/sem",
  "version": "0.2.0",
  "description": "Headless CLI OCPP charger simulator for interactive testing and debugging",
  "type": "module",
  "bin": {
    "sem": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
